VITE_OPENAI_API_KEY=your_openai_api_key_here
VITE_OPENAI_VISION_MODEL=gpt-5.2
VITE_OPENAI_VISION_FALLBACK_MODELS=gpt-5.2,gpt-4.1-mini
VITE_OPENAI_STT_MODEL=gpt-4o-mini-transcribe
VITE_OPENAI_ENABLE_WEB_SEARCH=true
# Dev-only: where Vite proxies /api requests.
# Default in vite.config.ts points to aiProxy function endpoint.
# Override this if you want another backend (for example emulator host).
VITE_DEV_API_PROXY_TARGET=https://asia-southeast2-sehatai-68f20.cloudfunctions.net/aiProxy
VITE_AI_PROXY_BASE_URL=/api
VITE_ENABLE_AI_PROXY=true
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.asia-southeast1.firebasedatabase.app
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_firebase_app_id_here
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase Functions / backend env:
# OPENAI_API_KEY=your_openai_api_key_here
# FIREBASE_WEB_API_KEY=your_firebase_web_api_key_here
# ADMIN_EMAILS=admin1@example.com,admin2@example.com
# SUPER_ADMIN_EMAILS=admin1@example.com
