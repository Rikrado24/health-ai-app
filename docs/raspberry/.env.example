API_ENDPOINT=https://asia-southeast2-sehatai-68f20.cloudfunctions.net/aiProxy/device/measurement
DEVICE_API_KEY=isi_kunci_device_yang_sama_dengan_functions_env
OWNER_UID=isi_uid_user_target
OWNER_EMAIL=user@example.com
DEVICE_ID=raspi-clinic-01
USE_MOCK_SENSORS=1
WEIGHT_SENSOR_MODE=hx711
HEIGHT_SENSOR_MODE=tof
HX711_DOUT_PIN=5
HX711_SCK_PIN=6
HX711_GAIN=128
HX711_SCALE_KG=100000.0
HX711_OFFSET=0
MOUNT_HEIGHT_CM=200.0
TOF_HEIGHT_OFFSET_CM=0.0
AUTO_TARE_ON_START=1
HEIGHT_SAMPLE_COUNT=8
WEIGHT_SAMPLE_COUNT=8
HEIGHT_STABILITY_THRESHOLD=0.8
WEIGHT_STABILITY_THRESHOLD=0.2
SENSOR_READY_TIMEOUT_SEC=2.0
REQUEST_TIMEOUT_SEC=15.0
